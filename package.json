{
  "name": "@xxmaru10/cronos-projection",
  "version": "1.0.5",
  "description": "Lógica de projeção de estado compartilhada entre frontend e backend do CronosVTT",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "files": [
    "dist"
  ],
  "exports": {
    ".": {
      "require": "./dist/index.js",
      "types": "./dist/index.d.ts"
    },
    "./systems/fate": {
      "require": "./dist/systems/fate/index.js",
      "types": "./dist/systems/fate/index.d.ts"
    },
    "./systems/vampire": {
      "require": "./dist/systems/vampire/index.js",
      "types": "./dist/systems/vampire/index.d.ts"
    },
    "./systems/fate-accelerated": {
      "require": "./dist/systems/fate-accelerated/index.js",
      "types": "./dist/systems/fate-accelerated/index.d.ts"
    }
  },
  "scripts": {
    "build": "tsc",
    "typecheck": "tsc --noEmit"
  },
  "publishConfig": {
    "registry": "https://npm.pkg.github.com"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/xxmaru10/cronos-projection.git"
  },
  "devDependencies": {
    "typescript": "^5.0.0"
  },
  "private": false
}
